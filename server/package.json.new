  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node --watch index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev:js": "node --watch index.js"
  },
  "dependencies": {
