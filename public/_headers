# Cloudflare Pages headers
# CSP is handled via meta tag in index.html

# HTML pages: never cache (so users always get latest chunk references)
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed assets: cache forever (filenames change on rebuild)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
